# Copy to .env in this folder (server/.env)
# Local Docker: use docker-compose defaults below.
# Render: paste "Internal Database URL" from your Render PostgreSQL (or External if the API is outside Render's network).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catalog

# TLS for pg (auto: SSL off for localhost/docker "db", on for remote hosts like *.render.com).
# Override if needed: DATABASE_SSL=true | false
# DATABASE_SSL=false

# Optional: max pool size (default 10)
# PGPOOL_MAX=10

# Dev API port (must match Vite proxy default in vite.config.ts unless you set API_PROXY_TARGET in repo root .env)
PORT=3002

# Admin login (password min 5 characters; default dev: admin / admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Signing key for JWT (use a long random string in production)
JWT_SECRET=dev-only-change-to-at-least-32-chars!!

# Optional: comma-separated allowed origins when frontend is on another host
# CORS_ORIGIN=http://localhost:5173

# Optional: override folder scanned by GET /api/images (default: ../public/images from server/)
# IMAGES_DIR=C:\path\to\React-Store-Catalog\public\images
